{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:yuansheng-kit:plugins:craft:contracts:v1",
  "title": "Yuansheng Craft Contract v1",
  "description": "Platform-neutral, content-addressed workflow contracts for Yuansheng Craft.",
  "oneOf": [
    {
      "$ref": "#/$defs/root_cause_artifact"
    },
    {
      "$ref": "#/$defs/blueprint_review_subject"
    },
    {
      "$ref": "#/$defs/blueprint_review_attestation"
    },
    {
      "$ref": "#/$defs/repository_binding"
    },
    {
      "$ref": "#/$defs/patch_plan"
    },
    {
      "$ref": "#/$defs/mutation_authorization"
    },
    {
      "$ref": "#/$defs/diff_manifest"
    },
    {
      "$ref": "#/$defs/patch_candidate"
    },
    {
      "$ref": "#/$defs/verification_source"
    },
    {
      "$ref": "#/$defs/verification_manifest"
    },
    {
      "$ref": "#/$defs/verification_authorization"
    },
    {
      "$ref": "#/$defs/phase_command_manifest"
    },
    {
      "$ref": "#/$defs/phase_command_authorization"
    },
    {
      "$ref": "#/$defs/criterion_evidence"
    },
    {
      "$ref": "#/$defs/patch_review"
    },
    {
      "$ref": "#/$defs/delivery"
    },
    {
      "$ref": "#/$defs/workflow_state"
    },
    {
      "$ref": "#/$defs/action_journal"
    }
  ],
  "$defs": {
    "artifact_type": {
      "enum": [
        "root-cause",
        "blueprint-review-subject",
        "blueprint-review-attestation",
        "repository-binding",
        "patch-plan",
        "mutation-authorization",
        "diff-manifest",
        "patch-candidate",
        "verification-source",
        "verification-manifest",
        "verification-authorization",
        "phase-command-manifest",
        "phase-command-authorization",
        "criterion-evidence",
        "patch-review",
        "delivery",
        "workflow-state",
        "action-journal"
      ]
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "opaque_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*:[A-Za-z0-9_-]{16,128}$"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "utc_time": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{3})?Z$"
    },
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*//)(?!.*\\\\)[^\\u0000]+$"
    },
    "realpath": {
      "type": "string",
      "minLength": 2,
      "pattern": "^/(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*//)(?!.*\\\\)[^\\u0000]+$"
    },
    "artifact_ref": {
      "title": "ArtifactRef",
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_type", "artifact_version", "digest"],
      "properties": {
        "artifact_type": {
          "$ref": "#/$defs/artifact_type"
        },
        "artifact_version": {
          "const": 1
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "principal": {
      "title": "PrincipalAudit",
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_id", "session_id"],
      "properties": {
        "agent_id": {
          "type": "string",
          "pattern": "^ys-craft(?:-[a-z][a-z0-9-]*)?$"
        },
        "session_id": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    },
    "workflow_entry_context": {
      "title": "WorkflowEntryContext",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["problem", "repository_binding_ref", "strategy"],
          "properties": {
            "problem": {
              "$ref": "#/$defs/non_empty_string"
            },
            "repository_binding_ref": {
              "$ref": "#/$defs/artifact_ref"
            },
            "strategy": {
              "const": "problem-description"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "attestation_ref",
            "repository_binding_ref",
            "review_subject_ref",
            "root_cause_ref",
            "strategy"
          ],
          "properties": {
            "attestation_ref": {
              "$ref": "#/$defs/artifact_ref"
            },
            "repository_binding_ref": {
              "$ref": "#/$defs/artifact_ref"
            },
            "review_subject_ref": {
              "$ref": "#/$defs/artifact_ref"
            },
            "root_cause_ref": {
              "$ref": "#/$defs/artifact_ref"
            },
            "strategy": {
              "const": "root-cause-import"
            }
          }
        }
      ]
    },
    "blocked_context": {
      "title": "BlockedWorkflowContext",
      "type": "object",
      "additionalProperties": false,
      "required": ["from_phase", "reason", "remediation_phase"],
      "properties": {
        "from_phase": {
          "enum": [
            "building",
            "delivering",
            "intake",
            "planning",
            "reviewing",
            "root_cause",
            "verifying"
          ]
        },
        "reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "remediation_phase": {
          "enum": ["building", "planning", "root_cause", "verifying"]
        }
      }
    },
    "artifact_base": {
      "title": "ArtifactBase",
      "type": "object",
      "required": ["artifact_digest", "artifact_type", "artifact_version", "created_at"],
      "properties": {
        "artifact_digest": {
          "$ref": "#/$defs/digest"
        },
        "artifact_type": {
          "$ref": "#/$defs/artifact_type"
        },
        "artifact_version": {
          "const": 1
        },
        "created_at": {
          "$ref": "#/$defs/utc_time"
        }
      }
    },
    "workflow_base": {
      "title": "WorkflowArtifactBase",
      "type": "object",
      "required": ["workflow_id"],
      "properties": {
        "workflow_id": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    },
    "root_cause_item": {
      "title": "RootCauseItem",
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement"],
      "properties": {
        "id": {
          "$ref": "#/$defs/opaque_id"
        },
        "statement": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "observed_fact": {
      "title": "ObservedFact",
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_refs", "id", "statement"],
      "properties": {
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/artifact_ref"
          }
        },
        "id": {
          "$ref": "#/$defs/opaque_id"
        },
        "statement": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "inference": {
      "title": "Inference",
      "type": "object",
      "additionalProperties": false,
      "required": ["basis_fact_ids", "id", "statement"],
      "properties": {
        "basis_fact_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/opaque_id"
          }
        },
        "id": {
          "$ref": "#/$defs/opaque_id"
        },
        "statement": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "criterion": {
      "title": "VerificationCriterion",
      "type": "object",
      "additionalProperties": false,
      "required": ["fact_ids", "id", "required", "statement"],
      "properties": {
        "fact_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/opaque_id"
          }
        },
        "id": {
          "$ref": "#/$defs/opaque_id"
        },
        "required": {
          "type": "boolean"
        },
        "statement": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "blueprint_provenance": {
      "title": "BlueprintProvenance",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attestation_ref",
        "blueprint_canonical_digest",
        "blueprint_raw_blob_digest",
        "review_subject_ref",
        "sealed_function_directory_digest"
      ],
      "properties": {
        "attestation_ref": {
          "$ref": "#/$defs/artifact_ref"
        },
        "blueprint_canonical_digest": {
          "$ref": "#/$defs/digest"
        },
        "blueprint_raw_blob_digest": {
          "$ref": "#/$defs/digest"
        },
        "review_subject_ref": {
          "$ref": "#/$defs/artifact_ref"
        },
        "sealed_function_directory_digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "root_cause_artifact": {
      "title": "RootCauseArtifact",
      "type": "object",
      "allOf": [
        {
          "$ref": "#/$defs/artifact_base"
        },
        {
          "$ref": "#/$defs/workflow_base"
        },
        {
          "type": "object",
          "required": [
            "artifact_type",
            "criteria",
            "entry_strategy",
            "facts",
            "gaps",
            "inferences",
            "problem_summary",
            "provenance",
            "status"
          ],
          "properties": {
            "artifact_type": {
              "const": "root-cause"
            },
            "criteria": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/criterion"
              }
            },
            "entry_strategy": {
              "enum": ["problem-description", "root-cause-import"]
            },
            "facts": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/observed_fact"
              }
            },
            "gaps": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/root_cause_item"
              }
            },
            "inferences": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/inference"
              }
            },
            "problem_summary": {
              "$ref": "#/$defs/non_empty_string"
            },
            "provenance": {
              "oneOf": [
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["source", "source_refs"],
                  "properties": {
                    "source": {
                      "const": "problem-description"
                    },
                    "source_refs": {
                      "type": "array",
                      "minItems": 1,
                      "uniqueItems": true,
                      "items": {
                        "$ref": "#/$defs/artifact_ref"
                      }
                    }
                  }
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["blueprint", "source"],
                  "properties": {
                    "blueprint": {
                      "$ref": "#/$defs/blueprint_provenance"
                    },
                    "source": {
                      "const": "root-cause-blueprint"
                    }
                  }
                }
              ]
            },
            "status": {
              "const": "confirmed"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "blueprint_review_subject": {
      "title": "BlueprintReviewSubject",
      "type": "object",
      "allOf": [
        {
          "$ref": "#/$defs/artifact_base"
        },
        {
          "type": "object",
          "required": [
            "artifact_type",
            "blueprint_canonical_digest",
            "blueprint_raw_blob_digest",
            "candidate_payload_digest",
            "final_status",
            "function_identity",
            "overall_status",
            "repository_binding_ref",
            "sealed_function_directory_digest",
            "source_path",
            "validation"
          ],
          "properties": {
            "artifact_type": {
              "const": "blueprint-review-subject"
            },
            "blueprint_canonical_digest": {
              "$ref": "#/$defs/digest"
            },
            "blueprint_raw_blob_digest": {
              "$ref": "#/$defs/digest"
            },
            "candidate_payload_digest": {
              "$ref": "#/$defs/digest"
            },
            "final_status": {
              "enum": [
                "confirmed_root_cause",
                "probable_root_cause",
                "insufficient_evidence",
                "false_alarm"
              ]
            },
            "overall_status": {
              "enum": ["confirmed", "probable", "insufficient_evidence", "false_alarm"]
            },
            "repository_binding_ref": {
              "$ref": "#/$defs/artifact_ref"
            },
            "sealed_function_directory_digest": {
              "$ref": "#/$defs/digest"
            },
            "source_path": {
              "oneOf": [
                {
                  "$ref": "#/$defs/relative_path"
                },
                {
                  "type": "null"
                }
              ]
            },
            "function_identity": {
              "$ref": "#/$defs/trace_function_identity"
            },
            "validation": {
              "$ref": "#/$defs/sealed_validation_summary"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "blueprint_review_attestation": {
      "title": "BlueprintReviewAttestation",
      "type": "object",
      "allOf": [
        {
          "$ref": "#/$defs/artifact_base"
        },
        {
          "type": "object",
          "required": [
            "action",
            "artifact_type",
            "blueprint_canonical_digest",
            "repository_binding_ref",
            "resolved_repository",
            "review_subject_digest",
            "review_subject_ref",
            "reviewer_session_id",
            "sealed_function_directory_digest"
          ],
          "properties": {
            "action": {
              "enum": ["allow", "deny"]
            },
            "artifact_type": {
              "const": "blueprint-review-attestation"
            },
            "blueprint_canonical_digest": {
              "$ref": "#/$defs/digest"
            },
            "repository_binding_ref": {
              "$ref": "#/$defs/artifact_ref"
            },
            "resolved_repository": {
              "$ref": "#/$defs/resolved_repository"
            },
            "review_subject_digest": {
              "$ref": "#/$defs/digest"
            },
            "review_subject_ref": {
              "$ref": "#/$defs/artifact_ref"
            },
            "reviewer_session_id": {
              "$ref": "#/$defs/opaque_id"
            },
            "sealed_function_directory_digest": {
              "$ref": "#/$defs/digest"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "trace_function_identity": {
      "title": "TraceFunctionIdentity",
      "type": "object",
      "additionalProperties": false,
      "required": ["function_name", "rank", "software", "test_case"],
      "properties": {
        "function_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "rank": {
          "type": "string",
          "pattern": "^[0-9]{3}$"
        },
        "software": {
          "$ref": "#/$defs/non_empty_string"
        },
        "test_case": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "evidence_digest": {
      "title": "SealedEvidenceDigest",
      "type": "object",
      "additionalProperties": false,
      "required": ["digest", "path"],
      "properties": {
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "path": {
          "$ref": "#/$defs/relative_path"
        }
      }
    },
    "sealed_validation_summary": {
      "title": "SealedValidationSummary",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_to_evidence_digest",
        "diagnosis_digest",
        "evidence",
        "machine_validation_digest",
        "semantic_validation_digest"
      ],
      "properties": {
        "claim_to_evidence_digest": {
          "$ref": "#/$defs/digest"
        },
        "diagnosis_digest": {
          "$ref": "#/$defs/digest"
        },
        "evidence": {
          "type": "array",
          "minItems": 3,
          "items": {
            "$ref": "#/$defs/evidence_digest"
          }
        },
        "machine_validation_digest": {
          "$ref": "#/$defs/digest"
        },
        "semantic_validation_digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "resolved_repository": {
      "title": "ResolvedRepository",
      "type": "object",
      "additionalProperties": false,
      "required": ["commit_sha", "repository_url", "source_realpath", "target_worktree_realpath"],
      "properties": {
        "commit_sha": {
          "type": "string",
          "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$"
        },
        "repository_url": {
          "type": "string",
          "format": "uri",
          "pattern": "^(?:https?|ssh)://"
        },
        "source_realpath": {
          "oneOf": [
            {
              "$ref": "#/$defs/realpath"
            },
            {
              "type": "null"
            }
          ]
        },
        "target_worktree_realpath": {
          "$ref": "#/$defs/realpath"
        }
      }
    },
    "repository_binding": {
      "title": "RepositoryBinding",
      "type": "object",
      "allOf": [
        {
          "$ref": "#/$defs/artifact_base"
        },
        {
          "type": "object",
          "required": [
            "artifact_type",
            "commit_sha",
            "git_root_realpath",
            "preparation_mode",
            "product_root_realpath",
            "repository_url",
            "target_worktree_realpath",
            "tree_digest"
          ],
          "properties": {
            "artifact_type": {
              "const": "repository-binding"
            },
            "commit_sha": {
              "type": "string",
              "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$"
            },
            "git_root_realpath": {
              "$ref": "#/$defs/realpath"
            },
            "preparation_mode": {
              "enum": ["managed", "manual"]
            },
            "product_root_realpath": {
              "$ref": "#/$defs/realpath"
            },
            "repository_url": {
              "type": "string",
              "format": "uri",
              "pattern": "^(?:https?|ssh)://"
            },
            "target_worktree_realpath": {
              "$ref": "#/$defs/realpath"
            },
            "tree_digest": {
              "$ref": "#/$defs/digest"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "planned_change": {
      "title": "PlannedChange",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "criterion_ids",
        "id",
        "operation",
        "path",
        "reason",
        "root_cause_item_ids",
        "source_path"
      ],
      "properties": {
        "criterion_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/opaque_id"
          }
        },
        "id": {
          "$ref": "#/$defs/opaque_id"
        },
        "operation": {
          "enum": ["create", "delete", "modify", "rename"]
        },
        "path": {
          "$ref": "#/$defs/relative_path"
        },
        "reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "root_cause_item_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/opaque_id"
          }
        },
        "source_path": {
          "oneOf": [
            {
              "$ref": "#/$defs/relative_path"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "patch_plan": {
      "title": "PatchPlan",
      "type": "object",
      "allOf": [
        {
          "$ref": "#/$defs/artifact_base"
        },
        {
          "$ref": "#/$defs/workflow_base"
        },
        {
          "type": "object",
          "required": [
            "artifact_type",
            "changes",
            "criterion_ids",
            "non_goals",
            "objectives",
            "plan_revision",
            "root_cause_ref",
            "status"
          ],
          "properties": {
            "artifact_type": {
              "const": "patch-plan"
            },
            "changes": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/planned_change"
              }
            },
            "criterion_ids": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "$ref": "#/$defs/opaque_id"
              }
            },
            "non_goals": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "$ref": "#/$defs/non_empty_string"
              }
            },
            "objectives": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "$ref": "#/$defs/non_empty_string"
              }
            },
            "plan_revision": {
              "type": "integer",
              "minimum": 1
            },
            "root_cause_ref": {
              "$ref": "#/$defs/artifact_ref"
            },
            "status": {
              "const": "approved"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "authorized_change": {
      "title": "AuthorizedChange",
      "type": "object",
      "additionalProperties": false,
      "required": ["operation", "path", "planned_change_id", "source_path"],
      "properties": {
        "operation": {
          "enum": ["create", "delete", "modify", "rename"]
        },
        "path": {
          "$ref": "#/$defs/relative_path"
        },
        "planned_change_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "source_path": {
          "oneOf": [
            {
              "$ref": "#/$defs/relative_path"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "mutation_authorization": {
      "title": "MutationAuthorization",
      "type": "object",
      "allOf": [
        {
          "$ref": "#/$defs/artifact_base"
        },
        {
          "$ref": "#/$defs/workflow_base"
        },
        {
          "type": "object",
          "required": [
            "action",
            "artifact_type",
            "authorized_changes",
            "authorized_revision",
            "baseline_commit",
            "capability",
            "plan_ref",
            "principal",
            "repository_binding_ref",
            "target_worktree_realpath"
          ],
          "properties": {
            "action": {
              "const": "allow"
            },
            "artifact_type": {
              "const": "mutation-authorization"
            },
            "authorized_changes": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/authorized_change"
              }
            },
            "authorized_revision": {
              "type": "integer",
              "minimum": 1
            },
