{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:yuansheng-kit:trace:perf-data-validation-report:v1",
  "title": "Yuansheng Trace perf data validation report v1",
  "description": "Internal, versioned handoff from the perf data validator to the platform-neutral trace workflow.",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "kind", "report_status", "metadata", "testcases", "issues"],
  "properties": {
    "contract_version": {
      "const": 1
    },
    "kind": {
      "const": "perf_data_validation_report"
    },
    "report_status": {
      "enum": ["usable", "unusable"]
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "testcases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/testcase"
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/issue"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "type": "object",
        "properties": {
          "report_status": {
            "const": "usable"
          }
        },
        "required": ["report_status"]
      },
      "then": {
        "type": "object",
        "properties": {
          "testcases": {
            "type": "array",
            "contains": {
              "type": "object",
              "properties": {
                "status": {
                  "const": "valid"
                }
              },
              "required": ["status"]
            },
            "minContains": 1
          }
        }
      },
      "else": {
        "type": "object",
        "properties": {
          "testcases": {
            "type": "array",
            "not": {
              "type": "array",
              "contains": {
                "type": "object",
                "properties": {
                  "status": {
                    "const": "valid"
                  }
                },
                "required": ["status"]
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "byte_count": {
      "type": "string",
      "pattern": "^(?:0|[1-9][0-9]*)$"
    },
    "logical_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)(?:\\.|\\.\\.)(?:/|$))(?!.*//)(?!.*\\\\)(?!.*\\u0000).+$"
    },
    "path_segment": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!\\.\\.?$)(?!.*[/\\\\\\u0000]).+$"
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "bytes", "sha256"],
      "properties": {
        "path": {
          "$ref": "#/$defs/logical_path"
        },
        "bytes": {
          "$ref": "#/$defs/byte_count"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "code", "path", "detail"],
      "properties": {
        "severity": {
          "enum": ["error", "warning"]
        },
        "code": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "oneOf": [
            {
              "$ref": "#/$defs/logical_path"
            },
            {
              "type": "null"
            }
          ]
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "file",
        "repository_url",
        "test_branch",
        "commit_hash",
        "build_isa",
        "issues"
      ],
      "properties": {
        "status": {
          "enum": ["present", "missing", "invalid"]
        },
        "file": {
          "oneOf": [
            {
              "$ref": "#/$defs/file"
            },
            {
              "type": "null"
            }
          ]
        },
        "repository_url": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "test_branch": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "commit_hash": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "build_isa": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "issues": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/issue"
          }
        }
      }
    },
    "annotate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rank", "function", "file"],
      "properties": {
        "rank": {
          "type": "string",
          "pattern": "^[0-9]{3}$"
        },
        "function": {
          "$ref": "#/$defs/path_segment"
        },
        "file": {
          "$ref": "#/$defs/file"
        }
      }
    },
    "testcase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "perf_stat", "annotate_directory", "annotates", "issues"],
      "properties": {
        "name": {
          "$ref": "#/$defs/path_segment"
        },
        "status": {
          "enum": ["valid", "invalid"]
        },
        "perf_stat": {
          "oneOf": [
            {
              "$ref": "#/$defs/file"
            },
            {
              "type": "null"
            }
          ]
        },
        "annotate_directory": {
          "oneOf": [
            {
              "$ref": "#/$defs/logical_path"
            },
            {
              "type": "null"
            }
          ]
        },
        "annotates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/annotate"
          }
        },
        "issues": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/issue"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "type": "object",
            "properties": {
              "status": {
                "const": "valid"
              }
            },
            "required": ["status"]
          },
          "then": {
            "type": "object",
            "properties": {
              "perf_stat": {
                "$ref": "#/$defs/file"
              },
              "annotate_directory": {
                "$ref": "#/$defs/logical_path"
              },
              "annotates": {
                "type": "array",
                "minItems": 1
              },
              "issues": {
                "type": "array",
                "not": {
                  "type": "array",
                  "contains": {
                    "type": "object",
                    "properties": {
                      "severity": {
                        "const": "error"
                      }
                    },
                    "required": ["severity"]
                  }
                }
              }
            }
          },
          "else": {
            "type": "object",
            "properties": {
              "issues": {
                "type": "array",
                "contains": {
                  "type": "object",
                  "properties": {
                    "severity": {
                      "const": "error"
                    }
                  },
                  "required": ["severity"]
                },
                "minContains": 1
              }
            }
          }
        }
      ]
    }
  }
}
