# .editorconfig --- EditorConfig of Yuansheng Kit project

root=true

[*]
charset=utf-8
end_of_line=lf
indent_size=8
indent_style=tab
insert_final_newline=true
max_line_length=70
tab_width=8
trim_trailing_whitespace=true

[*.json]
indent_style = space
indent_size = 2
tab_width=2

[*.md]
indent_size=2
indent_style=space
max_line_length=80
trim_trailing_whitespace=false

[*.nix]
indent_size = 2
indent_style=space
max_line_length=80
tab_width=2

[*.ts]
indent_size = 2
indent_style = space
max_line_length = 100
tab_width=2
