{
  "name": "yuansheng-kit",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "plugins/trace/opencode",
    "plugins/trace/tools",
    "tools/plugin-builder"
  ],
  "scripts": {
    "bun-nix:generate": "bun2nix -l bun.lock -o bun.nix -c ./",
    "format": "biome check --write .",
    "lint": "biome ci .",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.18.4",
    "@types/bun": "1.3.13",
    "json-schema-to-typescript": "15.0.4",
    "typescript": "5.9.3"
  }
}
