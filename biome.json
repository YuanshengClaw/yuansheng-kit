{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",

  "formatter": {
    "enabled": true,
    "useEditorconfig": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },

  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "quoteProperties": "asNeeded",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always"
    }
  },

  "json": {
    "formatter": {
      "enabled": true,
      "trailingCommas": "none"
    }
  },

  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },

  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },

  "files": {
    "includes": ["**/*.ts", "**/*.json", "**/*.jsonc", "!**/node_modules", "!**/dist", "!**/.git"]
  }
}
