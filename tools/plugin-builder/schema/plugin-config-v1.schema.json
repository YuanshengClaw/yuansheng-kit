{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:yuansheng-kit:plugin-builder:plugin-config:v1",
  "title": "Yuansheng plugin configuration v1",
  "description": "Internal typed configuration for resolving a platform-neutral plugin resource graph and one or more platform assembly targets.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "plugin", "resources", "platforms"],
  "properties": {
    "version": {
      "const": 1
    },
    "plugin": {
      "$ref": "#/$defs/plugin"
    },
    "resources": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "#/$defs/identifier"
      },
      "additionalProperties": {
        "$ref": "#/$defs/resource"
      }
    },
    "platforms": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "#/$defs/identifier"
      },
      "additionalProperties": {
        "$ref": "#/$defs/platform"
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "logicalPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)(?:\\.|\\.\\.)(?:/|$))(?!.*//)(?!.*\\\\)(?!.*\\u0000).+$"
    },
    "jsonValue": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "$ref": "#/$defs/jsonObject"
        }
      ]
    },
    "jsonObject": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/jsonValue"
      }
    },
    "plugin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "displayName"],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source": {
      "oneOf": [
        {
          "$ref": "#/$defs/fileSource"
        },
        {
          "$ref": "#/$defs/treeSource"
        }
      ]
    },
    "fileSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path"],
      "properties": {
        "kind": {
          "const": "file"
        },
        "path": {
          "$ref": "#/$defs/logicalPath"
        }
      }
    },
    "treeSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path"],
      "properties": {
        "kind": {
          "const": "tree"
        },
        "path": {
          "$ref": "#/$defs/logicalPath"
        }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "logicalPath", "source"],
      "properties": {
        "kind": {
          "$ref": "#/$defs/identifier"
        },
        "logicalPath": {
          "$ref": "#/$defs/logicalPath"
        },
        "source": {
          "$ref": "#/$defs/source"
        },
        "requires": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        }
      }
    },
    "handler": {
      "type": "object",
      "additionalProperties": false,
      "required": ["apiVersion", "resource", "export"],
      "properties": {
        "apiVersion": {
          "const": 1
        },
        "resource": {
          "$ref": "#/$defs/identifier"
        },
        "export": {
          "type": "string",
          "pattern": "^[A-Za-z_$][A-Za-z0-9_$]*$"
        }
      }
    },
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifactName", "roots", "handler", "configuration"],
      "properties": {
        "artifactName": {
          "type": "string",
          "minLength": 1
        },
        "roots": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "handler": {
          "$ref": "#/$defs/handler"
        },
        "configuration": {
          "$ref": "#/$defs/jsonObject"
        }
      }
    }
  }
}
