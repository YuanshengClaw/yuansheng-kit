{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:yuansheng-kit:plugin-builder:plugin-manifest:v1",
  "title": "Yuansheng plugin manifest v1",
  "description": "Internal manifest for resolving a platform-neutral plugin resource graph and one or more platform assembly targets.",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_version", "plugin", "resources", "platforms"],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "manifest_version": {
      "const": 1
    },
    "plugin": {
      "$ref": "#/$defs/plugin"
    },
    "resources": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/resource"
      }
    },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/platform"
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "logical_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)(?:\\.|\\.\\.)(?:/|$))(?!.*//)(?!.*\\\\)(?!.*\\u0000).+$"
    },
    "plugin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "display_name"],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source": {
      "oneOf": [
        {
          "$ref": "#/$defs/file_source"
        },
        {
          "$ref": "#/$defs/tree_source"
        }
      ]
    },
    "file_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "sha256"],
      "properties": {
        "kind": {
          "const": "file"
        },
        "path": {
          "$ref": "#/$defs/logical_path"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "tree_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "sha256"],
      "properties": {
        "kind": {
          "const": "tree"
        },
        "path": {
          "$ref": "#/$defs/logical_path"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "logical_path", "source", "requires"],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "kind": {
          "$ref": "#/$defs/identifier"
        },
        "logical_path": {
          "$ref": "#/$defs/logical_path"
        },
        "source": {
          "$ref": "#/$defs/source"
        },
        "requires": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        }
      }
    },
    "handler": {
      "type": "object",
      "additionalProperties": false,
      "required": ["api_version", "resource", "export"],
      "properties": {
        "api_version": {
          "const": 1
        },
        "resource": {
          "$ref": "#/$defs/identifier"
        },
        "export": {
          "type": "string",
          "pattern": "^[A-Za-z_$][A-Za-z0-9_$]*$"
        }
      }
    },
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "artifact_name", "roots", "handler", "configuration"],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "artifact_name": {
          "type": "string",
          "minLength": 1
        },
        "roots": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "handler": {
          "$ref": "#/$defs/handler"
        },
        "configuration": {
          "type": "object"
        }
      }
    }
  }
}
