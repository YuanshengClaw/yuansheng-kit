{
  "compilerOptions": {
    "target": "ES2022",

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "lib": ["ES2022"],

    "types": ["bun"],

    "strict": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,

    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    "allowImportingTsExtensions": false,

    "skipLibCheck": true,

    "noEmit": true
  },

  "include": [
    "plugins/trace/opencode/src/**/*.ts",
    "plugins/trace/opencode/tests/**/*.ts",
    "plugins/trace/tools/src/**/*.ts",
    "plugins/trace/tools/tests/**/*.ts",
    "tests/**/*.ts",
    "tools/plugin-builder/src/**/*.ts",
    "tools/plugin-builder/tests/**/*.ts"
  ],

  "exclude": ["coverage", "dist", "node_modules"]
}
